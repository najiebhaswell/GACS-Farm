```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py*.py.class
*.pyc.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Dependencies
pip-wheel-metadata/
requirements.txt.bak
*.egg-info/
.eggs/

# Build artifacts
build/
dist/
*.egg

# Logs
*.log

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*
# OS
.DS_Store
Thumbs.db

# Coverage
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Original rules preserved
```